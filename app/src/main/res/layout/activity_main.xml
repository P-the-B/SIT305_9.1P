<?xml version="1.0" encoding="utf-8"?>
<!--
    Home Screen
    - App name header
    - Map (fills remaining space)
    - Floating radius filter card
    - Stats strip
    - Action buttons
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- ══════════════════════════════════════════ -->
    <!--  HEADER                                    -->
    <!-- ══════════════════════════════════════════ -->
    <RelativeLayout
        android:id="@+id/appHeader"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Geo Lost &amp; Geo Found"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:letterSpacing="0.02" />

    </RelativeLayout>

    <!-- ══════════════════════════════════════════ -->
    <!--  MAP                                       -->
    <!-- ══════════════════════════════════════════ -->
    <fragment
        android:id="@+id/homeMap"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/appHeader"
        app:layout_constraintBottom_toTopOf="@+id/statsContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- FAB: re-centre to user location -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabMyLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="My location"
        android:src="@drawable/ic_my_location"
        app:fabSize="mini"
        app:tint="#1A73E8"
        app:backgroundTint="#FFFFFF"
        app:elevation="6dp"
        app:layout_constraintTop_toBottomOf="@+id/appHeader"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp" />

    <!-- ══════════════════════════════════════════ -->
    <!--  RADIUS FILTER — floating on map           -->
    <!-- ══════════════════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/radiusCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="#F0FFFFFF"
        app:layout_constraintBottom_toTopOf="@+id/statsContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.72"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Radius filter"
                    android:textSize="13sp"
                    android:textColor="#555555" />

                <TextView
                    android:id="@+id/txtRadius"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10 km"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#1A73E8" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seekRadius"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:max="499"
                android:progress="9"
                android:progressTint="#1A73E8"
                android:thumbTint="#1A73E8" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ══════════════════════════════════════════ -->
    <!--  STATS STRIP                               -->
    <!-- ══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/statsContainer"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="#FAFAFA"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toTopOf="@+id/buttonContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Lost -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/lostCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#E53935" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lost"
                android:textSize="13sp"
                android:textColor="#888888" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="36dp"
            android:background="#DDDDDD" />

        <!-- Found -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/foundCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#43A047" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Found"
                android:textSize="13sp"
                android:textColor="#888888" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="36dp"
            android:background="#DDDDDD" />

        <!-- Latest -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/latestDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Latest"
                android:textSize="13sp"
                android:textColor="#888888"
                android:gravity="center" />
        </LinearLayout>

    </LinearLayout>

    <!-- ══════════════════════════════════════════ -->
    <!--  BUTTONS                                   -->
    <!-- ══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/buttonContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnCreate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CREATE NEW ADVERT"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnShowAll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SHOW ALL LOST &amp; FOUND ITEMS" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>